# 应用配置
PROJECT_NAME=山东出版供应链管理公司业务平台
API_V1_PREFIX=/api/v1
# 生产环境请设为 false
DEBUG=false

# 数据库配置 (MySQL)
DB_HOST=127.0.0.1
DB_PORT=3306
DB_USER=root
DB_PASSWORD=your_password
DB_NAME=sd_publish_scm
DB_CHARSET=utf8mb4

# JWT —— 生产必须改成随机长字符串： openssl rand -hex 32
SECRET_KEY=change-me
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=1440

# 跨域来源（Nginx 同源部署时可留空；如需 IP 直连后端可加）
# 例：BACKEND_CORS_ORIGINS=["http://39.107.52.146"]
BACKEND_CORS_ORIGINS=[]

# AI 智能体（DeepSeek，OpenAI 兼容协议）。留空则 AI 诊断自动走内置规则引擎。
DEEPSEEK_API_KEY=
DEEPSEEK_BASE_URL=https://api.deepseek.com
DEEPSEEK_MODEL=deepseek-chat
