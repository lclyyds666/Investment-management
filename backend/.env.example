# 应用配置
PROJECT_NAME=山东出版供应链管理公司业务平台
API_V1_PREFIX=/api/v1
# 生产环境请设为 false
DEBUG=false

# 数据库配置 (MySQL)
DB_HOST=127.0.0.1
DB_PORT=3306
DB_USER=root
DB_PASSWORD=your_password
DB_NAME=sd_publish_scm
DB_CHARSET=utf8mb4

# JWT —— 生产必须改成随机长字符串： openssl rand -hex 32
SECRET_KEY=change-me
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=1440

# Redis —— 用于图形验证码存储 + 登录防爆破计数。
# 留空或连接失败时自动回退进程内存实现（单机开发可不装 Redis，功能不受影响）。
# 例：REDIS_URL=redis://127.0.0.1:6379/0
REDIS_URL=

# 登录安全
# 联调/Swagger 调试时可临时设 CAPTCHA_ENABLED=false 关闭图形验证码
CAPTCHA_ENABLED=true
CAPTCHA_TTL_SECONDS=120
LOGIN_MAX_FAILURES=5
LOGIN_LOCK_MINUTES=30
DEFAULT_PASSWORD=123456
PASSWORD_MIN_LENGTH=6

# 跨域来源（Nginx 同源部署时可留空；如需 IP 直连后端可加）
# 例：BACKEND_CORS_ORIGINS=["http://39.107.52.146"]
BACKEND_CORS_ORIGINS=[]

# AI 智能体（DeepSeek，OpenAI 兼容协议）。留空则 AI 诊断自动走内置规则引擎。
DEEPSEEK_API_KEY=
DEEPSEEK_BASE_URL=https://api.deepseek.com
DEEPSEEK_MODEL=deepseek-chat
